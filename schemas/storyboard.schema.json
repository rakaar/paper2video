{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Paper2Video Storyboard",
  "type": "object",
  "additionalProperties": false,
  "required": ["paper", "scenes"],
  "properties": {
    "paper": {
      "type": "object",
      "additionalProperties": true,
      "required": ["title"],
      "properties": {
        "title": {"type": "string", "minLength": 1},
        "shortTitle": {"type": "string"},
        "citation": {"type": "string"},
        "doi": {"type": "string"}
      }
    },
    "scenes": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/definitions/scene"}
    }
  },
  "definitions": {
    "scene": {
      "type": "object",
      "additionalProperties": true,
      "required": ["kind", "durationFrames", "title", "bullets", "narration", "evidence"],
      "properties": {
        "kind": {"enum": ["intro", "figure"]},
        "durationFrames": {"type": "integer", "minimum": 1},
        "eyebrow": {"type": "string"},
        "figure": {"type": "string"},
        "asset": {"type": "string"},
        "title": {"type": "string", "minLength": 1},
        "bullets": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "narration": {"type": "string", "minLength": 1},
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "focus": {
          "type": "object",
          "additionalProperties": false,
          "required": ["x", "y", "w", "h"],
          "properties": {
            "x": {"type": "number"},
            "y": {"type": "number"},
            "w": {"type": "number", "exclusiveMinimum": 0},
            "h": {"type": "number", "exclusiveMinimum": 0}
          }
        },
        "audio": {"type": "string"},
        "audioDurationSeconds": {"type": "number", "minimum": 0}
      },
      "allOf": [
        {
          "if": {
            "properties": {"kind": {"const": "figure"}},
            "required": ["kind"]
          },
          "then": {
            "required": ["figure", "asset"]
          }
        }
      ]
    }
  }
}
